{
  "name": "ascii-visual-engine",
  "version": "0.1.0",
  "description": "A reusable TypeScript framework for building expressive, real-time ASCII visual systems",
  "type": "module",
  "main": "./dist/ascii-visual-engine.cjs",
  "module": "./dist/ascii-visual-engine.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/ascii-visual-engine.js",
      "require": "./dist/ascii-visual-engine.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:demo": "vite build --config vite.demo.config.ts",
    "preview": "vite preview",
    "preview:demo": "vite preview --config vite.demo.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:all": "npm run build && REQUIRE_DIST=1 vitest run",
    "test:consumer": "npm run build && REQUIRE_DIST=1 vitest run tests/consumer-smoke.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nate-thousand/ascii-visual-engine.git"
  },
  "bugs": {
    "url": "https://github.com/nate-thousand/ascii-visual-engine/issues"
  },
  "homepage": "https://github.com/nate-thousand/ascii-visual-engine#readme",
  "devDependencies": {
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.0.5"
  },
  "keywords": [
    "ascii",
    "ascii-art",
    "visual-engine",
    "generative-art",
    "creative-coding",
    "canvas",
    "animation",
    "typescript",
    "midi",
    "audio-reactive",
    "visualization",
    "plantasonic"
  ],
  "license": "MIT"
}
