{
  "name": "plantasia-sound-engine",
  "version": "1.0.0-beta.1",
  "description": "Modular Sound World engine for Plantasia — species plugins, generative composition, expressive performance",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./public": {
      "types": "./dist/public.d.ts",
      "import": "./dist/public.js",
      "default": "./dist/public.js"
    }
  },
  "files": [
    "dist",
    "presets",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "sync-presets": "node scripts/sync-presets.mjs",
    "build": "tsc -p tsconfig.json",
    "postbuild": "cp -r src/presets/bundled dist/presets/bundled && node scripts/validate-presets.mjs && node scripts/validate-species-api.mjs && node scripts/test-ecology-controls.mjs && node scripts/test-generative-engine.mjs && node scripts/test-performance-engine.mjs && node scripts/test-species-registry.mjs && node scripts/test-lifecycle.mjs && node scripts/test-facade.mjs && node scripts/test-events.mjs && node scripts/test-scheduler.mjs && node scripts/test-midi.mjs && node scripts/validate-species-audio.mjs && node scripts/test-performance-budget.mjs && node scripts/test-v2-engine.mjs",
    "test": "npm run build && node scripts/test-v2-engine.mjs",
    "test:v2": "node scripts/test-v2-engine.mjs",
    "test:species": "node scripts/validate-species-api.mjs",
    "test:lifecycle": "node scripts/test-lifecycle.mjs",
    "test:facade": "node scripts/test-facade.mjs",
    "test:events": "node scripts/test-events.mjs",
    "test:scheduler": "node scripts/test-scheduler.mjs",
    "test:midi": "node scripts/test-midi.mjs",
    "test:audio": "node scripts/validate-species-audio.mjs",
    "test:budget": "node scripts/test-performance-budget.mjs",
    "test:registry": "node scripts/test-species-registry.mjs",
    "test:ecology": "node scripts/test-ecology-controls.mjs",
    "test:generative": "node scripts/test-generative-engine.mjs",
    "test:performance": "node scripts/test-performance-engine.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prebuild": "npm run clean && npm run sync-presets",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "dev": "vite --config vite.config.ts",
    "demo": "vite --config vite.demo.config.ts",
    "build:site": "npm run build && vite build --config vite.site.config.ts",
    "example:basic": "EXAMPLE_DIR=examples/basic vite --config vite.example.config.ts",
    "example:presets": "EXAMPLE_DIR=examples/presets vite --config vite.example.config.ts",
    "example:effects": "EXAMPLE_DIR=examples/effects vite --config vite.example.config.ts",
    "example:midi": "EXAMPLE_DIR=examples/midi vite --config vite.example.config.ts",
    "example:sequencing": "EXAMPLE_DIR=examples/sequencing vite --config vite.example.config.ts",
    "example:generative": "EXAMPLE_DIR=examples/generative vite --config vite.example.config.ts",
    "example:basic-engine": "EXAMPLE_DIR=examples/basic-engine vite --config vite.example.config.ts",
    "example:species-switching": "EXAMPLE_DIR=examples/species-switching vite --config vite.example.config.ts",
    "example:midi-performance": "EXAMPLE_DIR=examples/midi-performance vite --config vite.example.config.ts",
    "example:generative-playback": "EXAMPLE_DIR=examples/generative-playback vite --config vite.example.config.ts"
  },
  "keywords": [
    "audio",
    "synthesis",
    "tonejs",
    "plantasia",
    "botanical",
    "web-audio"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "tone": "^15.0.4"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "license": "MIT"
}
