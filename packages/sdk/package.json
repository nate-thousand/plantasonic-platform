{
  "name": "@plantasonic/platform",
  "version": "0.0.0",
  "private": true,
  "description": "Platform SDK — orchestration layer for the Plantasonic ecosystem",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@plantasonic/platform-types": "workspace:*",
    "ascii-visual-engine": "workspace:*",
    "plantasia-sound-engine": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
