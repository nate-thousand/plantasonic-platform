{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build && npm run showcase:build",
  "outputDirectory": "showcase/dist",
  "installCommand": "npm install && npm install --prefix showcase",
  "framework": null,
  "rewrites": [{ "source": "/((?!assets/).*)", "destination": "/index.html" }]
}
